---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				text-align: center;
				padding: 48px 24px 32px;
				max-width: 640px;
				margin: 0 auto;
			}
			.hero h1 { font-size: clamp(24px, 4vw, 38px); line-height: 1.2; margin-bottom: 12px; }
			.hero p { color: rgb(var(--gray)); font-size: 17px; margin-bottom: 28px; }

			.lead-magnet-banner {
				background: linear-gradient(135deg, #1e3a5f 0%, #0f2027 100%);
				border-radius: 14px;
				padding: 28px 28px;
				margin: 0 auto 48px;
				max-width: 640px;
				text-align: center;
				color: #fff;
			}
			.lead-magnet-banner .lm-badge {
				display: inline-block;
				background: #f59e0b;
				color: #000;
				font-size: 11px;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 1px;
				padding: 3px 10px;
				border-radius: 20px;
				margin-bottom: 12px;
			}
			.lead-magnet-banner h2 {
				font-size: 20px;
				margin-bottom: 8px;
				line-height: 1.3;
				color: #fff !important;
			}
			.lead-magnet-banner p {
				font-size: 14px;
				color: #cbd5e1;
				margin-bottom: 18px;
			}
			.lead-magnet-banner a {
				display: inline-block;
				background: #16a34a;
				color: #fff;
				font-weight: 700;
				padding: 12px 24px;
				border-radius: 8px;
				text-decoration: none;
				font-size: 15px;
			}
			.lead-magnet-banner a:hover { background: #15803d; }

			.links-section {
				max-width: 640px;
				margin: 0 auto;
				padding: 0 24px 64px;
			}
			.links-section h2 { font-size: 18px; margin-bottom: 16px; color: rgb(var(--gray-dark)); }
			.links-section ul { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 10px; }
			.links-section li a {
				display: block;
				padding: 14px 18px;
				background: rgb(var(--gray-light));
				border-radius: 8px;
				text-decoration: none;
				color: rgb(var(--gray-dark));
				font-size: 15px;
				transition: background 0.15s;
			}
			.links-section li a:hover { background: #e2e8f0; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<h1>Chegou a hora de zerar suas dívidas</h1>
				<p>Conteúdo prático para quem quer sair do vermelho de vez — sem enrolação, sem jargão, sem fórmula mágica.</p>
			</div>

			<div class="lead-magnet-banner">
				<div class="lm-badge">Grátis</div>
				<h2>Checklist: 30 Passos para Zerar Suas Dívidas em 90 Dias</h2>
				<p>O roteiro completo dividido em 3 fases — para você saber exatamente o que fazer e em qual ordem.</p>
				<a href="/checklist">Baixar o checklist gratuito →</a>
			</div>

			<div class="links-section">
				<h2>Explore o conteúdo</h2>
				<ul>
					<li><a href="/blog">→ Artigos sobre finanças pessoais</a></li>
					<li><a href="/checklist-completo">→ Checklist completo (30 passos)</a></li>
					<li><a href="/produto">→ Método Zerar Dívidas em 90 Dias</a></li>
				</ul>
			</div>
		</main>
		<Footer />
	</body>
</html>
