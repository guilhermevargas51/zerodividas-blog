			padding: 3px 10px;
			border-radius: 6px;
		}
		.bonus-emoji { font-size: 36px; margin-bottom: 20px; display: block; }
		.bonus-card h3 { font-size: 19px; font-weight: 700; color: #fff; margin-bottom: 12px; line-height: 1.25; }
		.bonus-card p { font-size: 14px; color: var(--muted); line-height: 1.65; }
		.bonus-value {
