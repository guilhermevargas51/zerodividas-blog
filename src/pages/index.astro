<script define:vars={{ DEADLINE }}>
	// ─── SCROLL: progress bar + nav fade + sticky cta + parallax ───
	const bar = document.getElementById('progress');
	const nav = document.getElementById('nav');
	const stickyCTA = document.getElementById('sticky-cta');
	const heroBg = document.getElementById('hero-bg');
	const heroGlow = document.getElementById('hero-glow');
	let ticking = false;

	function updateScroll() {
		const sy = window.scrollY;
		const docH = document.documentElement.scrollHeight - window.innerHeight;
		const pct = (sy / docH) * 100;
		if (bar) bar.style.width = pct + '%';
		if (nav) nav.classList.toggle('scrolled', sy > 80);
		if (stickyCTA) stickyCTA.classList.toggle('visible', sy > 800);
		// parallax (somente desktop e dentro do hero)
		if (sy < 900 && window.innerWidth > 760) {
			if (heroBg) heroBg.style.transform = `translateY(${sy * 0.35}px)`;
			if (heroGlow) heroGlow.style.transform = `translateY(${-sy * 0.18}px)`;
		}
		ticking = false;
	}
	window.addEventListener('scroll', () => {
		if (!ticking) {
			requestAnimationFrame(updateScroll);
			ticking = true;
		}
	}, { passive: true });

	// ─── COUNTDOWN ───
	function pad(n) { return String(n).padStart(2, '0'); }
	function tick() {
		const diff = new Date(DEADLINE).getTime() - Date.now();
		if (diff <= 0) return;
		const d = Math.floor(diff / 86400000);
		const h = Math.floor((diff % 86400000) / 3600000);
		const m = Math.floor((diff % 3600000) / 60000);
		const s = Math.floor((diff % 60000) / 1000);
		const ids = { 'cd-d': pad(d), 'cd-h': pad(h), 'cd-m': pad(m), 'cd-s': pad(s) };
		Object.entries(ids).forEach(([id, v]) => {
			const el = document.getElementById(id);
			if (el && el.textContent !== v) el.textContent = v;
		});
		const sUnit = document.getElementById('cd-secs');
		if (sUnit) {
			sUnit.classList.add('tick');
			setTimeout(() => sUnit.classList.remove('tick'), 280);
		}
	}
	tick();
	setInterval(tick, 1000);

	// ─── CALCULATOR ───
	const slider = document.getElementById('calc-slider');
	const debtEl = document.getElementById('calc-debt');
	const afterEl = document.getElementById('calc-after');
	const savingEl = document.getElementById('calc-saving');
	const ctaValEl = document.getElementById('calc-cta-value');
	const fmt = (n) => 'R$ ' + n.toLocaleString('pt-BR', { maximumFractionDigits: 0 });
	function updateCalc() {
		const debt = parseInt(slider.value);
		const after = Math.round(debt * 0.35);
		const saving = debt - after;
		if (debtEl) debtEl.textContent = fmt(debt);
		if (afterEl) afterEl.textContent = fmt(after);
		if (savingEl) savingEl.textContent = fmt(saving);
		if (ctaValEl) ctaValEl.textContent = fmt(saving);
		// fill the slider track
		const min = parseInt(slider.min), max = parseInt(slider.max);
		const pct = ((debt - min) / (max - min)) * 100;
		slider.style.backgroundSize = pct + '% 100%';
	}
	if (slider) {
		slider.addEventListener('input', updateCalc);
		updateCalc();
	}

	// ─── REVEAL ON SCROLL ───
	const ro = new IntersectionObserver((entries) => {
		entries.forEach(e => {
			if (e.isIntersecting) {
				e.target.classList.add('visible');
				ro.unobserve(e.target);
			}
		});
	}, { threshold: 0.12 });
	document.querySelectorAll('.r').forEach(el => ro.observe(el));

	// ─── FAQ ───
	document.querySelectorAll('.faq-btn').forEach(btn => {
		btn.addEventListener('click', () => {
			const item = btn.closest('.faq-item');
			const open = item.classList.contains('open');
			document.querySelectorAll('.faq-item.open').forEach(i => i.classList.remove('open'));
			if (!open) item.classList.add('open');
		});
	});

	// ─── VSL MODAL ───
	const vslTrigger = document.getElementById('vsl-trigger');
	const vslModal = document.getElementById('vsl-modal');
	const modalClose = document.getElementById('modal-close');
	function openModal() { if (vslModal) vslModal.classList.add('open'); }
	function closeModal() { if (vslModal) vslModal.classList.remove('open'); }
	if (vslTrigger) {
		vslTrigger.addEventListener('click', openModal);
		vslTrigger.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openModal(); } });
	}
	if (modalClose) modalClose.addEventListener('click', closeModal);
	if (vslModal) vslModal.addEventListener('click', (e) => { if (e.target === vslModal) closeModal(); });
	document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

	// ─── SOCIAL PROOF TOAST (rotation) ───
	const proofs = [
		{ title: 'Mariana de São Paulo', text: 'acabou de baixar o checklist gratuito' },
		{ title: 'Roberto de Belo Horizonte', text: 'iniciou o método há 12 minutos' },
		{ title: 'Ana Paula do Rio de Janeiro', text: 'renegociou R$ 4.300 esta semana' },
		{ title: 'Lucas de Curitiba', text: 'baixou a planilha de controle financeiro' },
		{ title: 'Camila de Salvador', text: 'concluiu a Fase 1 do método' },
		{ title: 'Pedro de Porto Alegre', text: 'economizou R$ 2.800 com o script de negociação' },
		{ title: 'Juliana de Fortaleza', text: 'limpou o nome em 67 dias' },
		{ title: 'Diego de Recife', text: 'acabou de garantir o acesso ao método' },
		{ title: 'Patrícia de Manaus', text: 'quitou a primeira dívida usando o passo a passo' },
		{ title: 'Rafael de Brasília', text: 'baixou o checklist agora' },
	];
	const toastWrap = document.getElementById('toast-wrap');
	let proofIdx = 0;
	function showToast() {
		if (!toastWrap || window.innerWidth < 640) return;
		const p = proofs[proofIdx % proofs.length];
		proofIdx++;
		const el = document.createElement('div');
		el.className = 'toast';
		el.innerHTML = `
			<div class="toast-icon">✓</div>
			<div class="toast-body">
				<div class="toast-title">${p.title}</div>
				<div class="toast-text">${p.text}</div>
			</div>
		`;
		toastWrap.appendChild(el);
		requestAnimationFrame(() => el.classList.add('show'));
		setTimeout(() => {
			el.classList.remove('show');
			setTimeout(() => el.remove(), 500);
		}, 4500);
	}
	// primeiro toast aos 12s, depois random 35-60s
	setTimeout(() => {
		showToast();
		setInterval(() => {
			if (Math.random() > 0.15) showToast();
		}, 35000 + Math.random() * 25000);
	}, 12000);
</script>

