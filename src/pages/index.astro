			font-size: 12px;
			font-weight: 700;
			padding: 5px 14px;
			border-radius: 20px;
		}
		.btn-cta-final {
			display: block;
			background: var(--green);
			color: #000;
			font-size: clamp(17px, 2.5vw, 21px);
			font-weight: 900;
			padding: 22px 56px;
			border-radius: 14px;
