			line-height: 1.75;
			font-style: italic;
			margin-bottom: 24px;
		}
		.tcard-result {
			display: inline-flex;
			align-items: center;
			gap: 6px;
			background: rgba(0,179,126,0.1);
			border: 1px solid rgba(0,179,126,0.2);
			color: var(--green);
			font-size: 12px;
