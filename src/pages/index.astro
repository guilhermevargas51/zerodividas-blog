			justify-content: center;
			gap: 12px;
			flex-wrap: wrap;
			margin-top: 32px;
		}
		.pay-method {
			display: inline-flex;
			align-items: center;
			gap: 8px;
			background: rgba(255,255,255,0.04);
			border: 1px solid var(--border);
			border-radius: 10px;
			padding: 10px 16px;
			font-size: 13px;
			color: var(--text);
			font-weight: 600;
		}
