			background: #fff;
			border-radius: 12px;
			border: 1px solid #e2e8f0;
			transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
		}
		.pain-item:hover {
			transform: translateX(6px);
			box-shadow: -4px 0 0 0 var(--red), 0 8px 24px rgba(0,0,0,0.06);
			border-color: #fecaca;
		}
		.pain-num {
			font-size: 11px;
			font-weight: 800;
			color: #fff;
			background: var(--red);
			width: 22px; height: 22px;
			border-radius: 6px;
			display: flex;
			align-items: center;
			justify-content: center;
			flex-shrink: 0;
			margin-top: 1px;
		}
		.pain-item-text { font-size: 15px; color: #374151; line-height: 1.5; font-weight: 500; }
		.pain-answer {
			background: var(--dark);
			border-radius: 16px;
			padding: 32px 36px;
			margin-top: 8px;
			color: #fff;
		}
		.pain-answer p { font-size: 18px; line-height: 1.6; color: #cbd5e1; }
		.pain-answer strong { color: var(--green); }

		/* ─── PRODUCT ─── */
		.product {
			background: var(--dark);
			padding: 100px 40px;
			position: relative;
			overflow: hidden;
		}
		.product::before {
			content: '';
			position: absolute;
			top: 50%; right: -200px;
			transform: translateY(-50%);
			width: 500px; height: 500px;
			background: radial-gradient(circle, rgba(0,179,126,0.06) 0%, transparent 70%);
			pointer-events: none;
		}
		.product-inner {
			max-width: 1100px;
			margin: 0 auto;
			display: grid;
			grid-template-columns: 1fr 1.2fr;
			gap: 80px;
			align-items: center;
		}
		@media (max-width: 800px) {
			.product-inner { grid-template-columns: 1fr; gap: 48px; }
		}
		.book-wrap { perspective: 1000px; }
		.book-3d {
			transform: rotateY(-12deg) rotateX(4deg);
			transition: transform 0.5s ease;
			transform-style: preserve-3d;
		}
		.book-wrap:hover .book-3d { transform: rotateY(-4deg) rotateX(2deg); }
		.book-face {
			background: linear-gradient(150deg, #1e3a8a 0%, #1d4ed8 50%, #1e40af 100%);
			border-radius: 4px 16px 16px 4px;
			padding: 48px 36px;
			position: relative;
			box-shadow:
				-8px 0 0 #1a336e,
				-14px 0 0 #162d62,
				0 24px 80px rgba(0,0,0,0.5);
		}
		.book-face::before {
			content: '';
			position: absolute;
			top: 0; left: 0; bottom: 0;
			width: 6px;
			background: linear-gradient(180deg, #2563eb, #1e40af);
			border-radius: 4px 0 0 4px;
		}
		.book-face::after {
			content: '';
			position: absolute;
			inset: 0;
			background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, transparent 50%);
			border-radius: 4px 16px 16px 4px;
		}
		.book-sticker {
			position: absolute;
			top: 16px; right: 16px;
			background: var(--amber);
			color: #000;
			font-size: 10px;
			font-weight: 800;
			text-transform: uppercase;
			letter-spacing: 0.5px;
			padding: 5px 10px;
			border-radius: 6px;
		}
		.book-title-wrap { position: relative; z-index: 1; }
		.book-face-title {
			font-size: 22px;
			font-weight: 900;
			color: #fff;
			line-height: 1.2;
			letter-spacing: -0.5px;
			margin-bottom: 8px;
		}
		.book-face-line {
			width: 48px; height: 3px;
			background: rgba(255,255,255,0.3);
			border-radius: 2px;
			margin: 16px 0;
		}
		.book-face-sub {
			font-size: 12px;
			color: #93c5fd;
			text-transform: uppercase;
			letter-spacing: 2px;
		}
		.book-contents {
			margin-top: 32px;
			display: flex;
			flex-direction: column;
			gap: 8px;
			position: relative;
			z-index: 1;
		}
		.book-item { display: flex; align-items: center; gap: 8px; font-size: 13px; color: rgba(255,255,255,0.7); }
		.book-check { color: var(--green); font-size: 12px; }

		.product-overline {
			font-size: 11px;
			font-weight: 700;
			color: var(--green);
			text-transform: uppercase;
			letter-spacing: 2.5px;
			margin-bottom: 20px;
		}
		.product-info h2 {
			font-size: clamp(28px, 4vw, 44px);
			font-weight: 900;
			color: #fff;
			margin-bottom: 20px;
			letter-spacing: -1.5px;
			line-height: 1.1;
		}
		.product-info p { color: var(--muted2); font-size: 16px; line-height: 1.75; margin-bottom: 32px; }
		.product-list { list-style: none; display: flex; flex-direction: column; gap: 12px; margin-bottom: 40px; }
		.product-list li {
			display: flex;
			align-items: flex-start;
			gap: 12px;
			font-size: 15px;
			color: var(--text);
			line-height: 1.55;
		}
		.pl-check {
			width: 20px; height: 20px;
			background: rgba(0,179,126,0.15);
			border: 1px solid rgba(0,179,126,0.3);
			border-radius: 50%;
			display: flex;
			align-items: center;
			justify-content: center;
			color: var(--green);
			font-size: 11px;
			font-weight: 700;
			flex-shrink: 0;
			margin-top: 1px;
		}
		.btn-product {
			display: inline-flex;
			align-items: center;
			gap: 10px;
			background: var(--green);
			color: #000;
			font-size: 16px;
			font-weight: 800;
			padding: 16px 36px;
			border-radius: 10px;
			text-decoration: none;
			transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
			box-shadow: 0 0 30px rgba(0,179,126,0.25);
		}
		.btn-product:hover {
			background: var(--green-dark);
			transform: translateY(-2px);
			box-shadow: 0 0 48px rgba(0,179,126,0.4);
		}

		/* ─── MODULES ─── */
		.modules { background: var(--black); padding: 100px 40px; }
		.modules-inner { max-width: 1100px; margin: 0 auto; }
		.section-head { margin-bottom: 64px; }
		.section-head-overline {
			font-size: 11px;
			font-weight: 700;
			color: var(--green);
			text-transform: uppercase;
			letter-spacing: 2.5px;
			margin-bottom: 16px;
		}
		.section-head h2 {
			font-size: clamp(30px, 5vw, 52px);
			font-weight: 900;
			letter-spacing: -2px;
			color: #fff;
			line-height: 1.08;
			max-width: 600px;
		}
		.section-head p {
			color: var(--muted2);
			font-size: 16px;
			margin-top: 14px;
