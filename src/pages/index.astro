			transform-origin: left;
			transition: transform 0.35s ease;
		}
		.module-cell:hover::after { transform: scaleX(1); }
		.mod-num {
			font-size: 48px;
			font-weight: 900;
			color: rgba(255,255,255,0.06);
			line-height: 1;
			margin-bottom: 16px;
			letter-spacing: -3px;
			font-variant-numeric: tabular-nums;
		}
		.module-cell h3 {
			font-size: 16px;
			font-weight: 700;
			color: #e2e8f0;
			margin-bottom: 10px;
			line-height: 1.35;
		}
		.module-cell p { font-size: 14px; color: var(--muted); line-height: 1.6; }
		.mod-bonus {
			background: rgba(245,158,11,0.05);
			border-top: 2px solid rgba(245,158,11,0.2);
		}
		.mod-bonus .mod-num { color: rgba(245,158,11,0.1); }
		.mod-bonus h3 { color: var(--amber); }

		/* ─── BONUS ─── */
		.bonus {
			background: var(--dark);
			padding: 100px 40px;
			position: relative;
			overflow: hidden;
		}
