---
const HOTMART_URL = "https://pay.hotmart.com/PRODUTO_ID";
const PRECO = "47";
const PRECO_ORIGINAL = "67";
// Data final da oferta
const DEADLINE = "2026-05-10T23:59:59";
---

<!doctype html>
<html lang="pt-BR">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>Zerar Dívidas em 90 Dias — O Método Completo</title>
	<meta name="description" content="Método completo para sair das dívidas em 90 dias. Ebook + planilha + passo a passo para quem tem salário e quer finalmente respirar no fim do mês." />
	<meta property="og:title" content="Zerar Dívidas em 90 Dias — O Método Completo" />
	<meta property="og:description" content="Ebook + planilha + bônus para sair das dívidas em 90 dias com um plano que funciona de verdade." />
	<meta property="og:type" content="website" />
	<meta property="og:url" content="https://zerardividas.com/" />
	<meta property="og:image" content="https://zerardividas.com/og-image.png" />
	<meta property="og:image:width" content="1200" />
	<meta property="og:image:height" content="630" />
	<link rel="canonical" href="https://zerardividas.com/" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
	<style>
		*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
		:root {
			--black: #080c12;
			--dark: #0d1520;
			--dark2: #111c2d;
			--green: #00b37e;
			--green-light: #00d893;
			--green-dark: #009a6a;
			--green-glow: rgba(0,179,126,0.25);
			--amber: #f59e0b;
			--white: #ffffff;
			--off-white: #f0f4f8;
			--text: #e2e8f0;
			--muted: #64748b;
			--muted2: #94a3b8;
			--border: rgba(255,255,255,0.08);
			--red: #ef4444;
		}
		html { scroll-behavior: smooth; }
		body {
			font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
			color: var(--white);
			background: var(--black);
			overflow-x: hidden;
		}

		/* ─── SCROLL PROGRESS ─── */
		#progress {
			position: fixed;
			top: 0; left: 0;
			height: 2px;
			width: 0%;
			background: linear-gradient(90deg, var(--green), var(--green-light));
			z-index: 9999;
			transition: width 0.08s linear;
		}

		/* ─── STICKY CTA BAR (aparece ao scroll) ─── */
		.sticky-cta {
			position: fixed;
			top: 0; left: 0; right: 0;
			background: rgba(8,12,18,0.96);
			backdrop-filter: blur(20px);
			-webkit-backdrop-filter: blur(20px);
			border-bottom: 1px solid var(--border);
			padding: 12px 32px;
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 16px;
			z-index: 200;
			transform: translateY(-100%);
			transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
		}
		.sticky-cta.visible { transform: translateY(0); }
		.sticky-cta-left {
			display: flex;
			align-items: center;
			gap: 14px;
			font-size: 14px;
			min-width: 0;
		}
		.sticky-cta-icon {
			width: 32px; height: 32px;
			background: var(--green);
			border-radius: 8px;
			display: flex;
			align-items: center;
			justify-content: center;
			color: #000;
			font-weight: 900;
			flex-shrink: 0;
			font-size: 14px;
		}
		.sticky-cta-text {
			color: var(--text);
			font-weight: 600;
			white-space: nowrap;
			overflow: hidden;
			text-overflow: ellipsis;
		}
		.sticky-cta-text strong { color: var(--green); }
		.sticky-cta-btn {
			background: var(--green);
			color: #000;
			font-weight: 800;
			font-size: 13px;
			padding: 9px 18px;
			border-radius: 8px;
			text-decoration: none;
			white-space: nowrap;
			transition: background 0.2s, transform 0.15s;
			flex-shrink: 0;
		}
		.sticky-cta-btn:hover { background: var(--green-dark); transform: translateY(-1px); }
		@media (max-width: 640px) {
			.sticky-cta { padding: 10px 14px; }
			.sticky-cta-text { font-size: 12px; }
			.sticky-cta-icon { width: 28px; height: 28px; font-size: 12px; }
		}

		/* ─── NAV ─── */
		.nav {
			position: fixed;
			top: 2px; left: 0; right: 0;
			z-index: 100;
			padding: 16px 40px;
			display: flex;
			align-items: center;
			justify-content: space-between;
			transition: opacity 0.3s, transform 0.3s, background 0.3s;
		}
		.nav.scrolled { opacity: 0; pointer-events: none; transform: translateY(-100%); }
		.nav-logo {
			display: flex;
			align-items: center;
			gap: 8px;
			font-size: 17px;
			font-weight: 800;
			color: #fff;
			text-decoration: none;
			letter-spacing: -0.5px;
		}
		.nav-logo-mark {
			width: 28px; height: 28px;
			background: var(--green);
			border-radius: 7px;
			display: flex;
			align-items: center;
			justify-content: center;
			color: #000;
			font-weight: 900;
			font-size: 14px;
			letter-spacing: 0;
		}
		.nav-logo em { font-style: normal; color: var(--green); }
		.nav-cta {
			background: var(--green);
			color: #000;
			font-weight: 700;
			font-size: 14px;
			padding: 10px 22px;
			border-radius: 8px;
			text-decoration: none;
			transition: background 0.2s, transform 0.15s;
		}
		.nav-cta:hover { background: var(--green-dark); transform: translateY(-1px); }

		/* ─── HERO ─── */
		.hero {
			min-height: 100vh;
			display: flex;
			flex-direction: column;
			justify-content: center;
			position: relative;
			overflow: hidden;
			padding: 120px 40px 80px;
		}
		.hero-bg {
			position: absolute;
			inset: 0;
			background:
				linear-gradient(to right, rgba(8,12,18,0.97) 30%, rgba(8,12,18,0.78) 100%),
				url('https://images.unsplash.com/photo-1554224155-8d04cb21cd6c?w=1600&q=80&auto=format&fit=crop') center/cover no-repeat;
			z-index: 0;
			will-change: transform;
		}
		.hero-bg::after {
			content: '';
			position: absolute;
			inset: 0;
			background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
			opacity: 0.3;
		}
		.hero-glow {
			position: absolute;
			bottom: -200px; left: -100px;
			width: 600px; height: 600px;
			background: radial-gradient(ellipse, rgba(0,179,126,0.14) 0%, transparent 65%);
			z-index: 0;
			pointer-events: none;
			animation: glow-breathe 6s ease-in-out infinite;
			will-change: transform;
		}
		@keyframes glow-breathe {
			0%, 100% { opacity: 0.7; transform: scale(1); }
			50% { opacity: 1; transform: scale(1.08); }
		}
		.hero-inner {
			position: relative;
			z-index: 1;
			max-width: 760px;
		}
		.hero-tag {
			display: inline-flex;
			align-items: center;
			gap: 8px;
			font-size: 12px;
			font-weight: 600;
			color: var(--green);
			text-transform: uppercase;
			letter-spacing: 2px;
			margin-bottom: 24px;
			opacity: 0;
			animation: fadeSlideDown 0.7s ease 0.2s both;
		}
		.hero-tag-dot {
			width: 6px; height: 6px;
			background: var(--green);
			border-radius: 50%;
			animation: blink 1.5s ease-in-out infinite;
		}
		@keyframes blink {
			0%, 100% { opacity: 1; }
			50% { opacity: 0.3; }
		}
		@keyframes fadeSlideDown {
			from { opacity: 0; transform: translateY(-16px); }
			to { opacity: 1; transform: translateY(0); }
		}
		@keyframes fadeSlideUp {
			from { opacity: 0; transform: translateY(24px); }
			to { opacity: 1; transform: translateY(0); }
		}

		/* CALCULATOR WIDGET */
		.calc {
			background: rgba(255,255,255,0.04);
			border: 1px solid var(--border);
			border-radius: 16px;
			padding: 22px 24px;
			margin-bottom: 32px;
			backdrop-filter: blur(8px);
			-webkit-backdrop-filter: blur(8px);
			max-width: 540px;
			opacity: 0;
			animation: fadeSlideUp 0.8s ease 0.35s both;
		}
		.calc-label {
			display: flex;
			align-items: center;
			gap: 8px;
			font-size: 13px;
			font-weight: 600;
			color: var(--text);
			margin-bottom: 14px;
		}
		.calc-label-icon {
			font-size: 14px;
		}
		.calc-slider-wrap {
			position: relative;
			margin-bottom: 16px;
		}
		.calc-slider {
			width: 100%;
			height: 6px;
			background: rgba(255,255,255,0.1);
			border-radius: 3px;
			outline: none;
			-webkit-appearance: none;
			appearance: none;
			cursor: pointer;
			background-image: linear-gradient(var(--green), var(--green));
			background-size: 25% 100%;
			background-repeat: no-repeat;
		}
		.calc-slider::-webkit-slider-thumb {
			-webkit-appearance: none;
			appearance: none;
			width: 22px; height: 22px;
			background: var(--green);
			border: 3px solid #fff;
			border-radius: 50%;
			cursor: grab;
			box-shadow: 0 0 0 4px rgba(0,179,126,0.2), 0 4px 12px rgba(0,0,0,0.3);
			transition: transform 0.15s;
		}
		.calc-slider::-webkit-slider-thumb:active { transform: scale(1.15); cursor: grabbing; }
		.calc-slider::-moz-range-thumb {
			width: 22px; height: 22px;
			background: var(--green);
			border: 3px solid #fff;
			border-radius: 50%;
			cursor: grab;
			box-shadow: 0 0 0 4px rgba(0,179,126,0.2), 0 4px 12px rgba(0,0,0,0.3);
		}
		.calc-rows {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 10px;
			margin-bottom: 16px;
			padding-top: 14px;
			border-top: 1px solid rgba(255,255,255,0.06);
		}
		.calc-row { display: flex; flex-direction: column; }
		.calc-row-label {
			font-size: 11px;
			color: var(--muted);
			text-transform: uppercase;
			letter-spacing: 1px;
			margin-bottom: 4px;
		}
		.calc-row-value {
			font-size: 22px;
			font-weight: 800;
			color: #fff;
			line-height: 1.1;
			letter-spacing: -0.5px;
			font-variant-numeric: tabular-nums;
		}
		.calc-row-value.green { color: var(--green); }
		.calc-row-value.strike {
			color: var(--muted);
			text-decoration: line-through;
			font-size: 18px;
		}
		.calc-saving {
			display: flex;
			align-items: center;
			justify-content: space-between;
			background: rgba(0,179,126,0.08);
			border: 1px solid rgba(0,179,126,0.2);
			border-radius: 10px;
			padding: 10px 14px;
			margin-bottom: 14px;
		}
		.calc-saving-label {
			font-size: 12px;
			color: var(--green);
			font-weight: 600;
		}
		.calc-saving-value {
			font-size: 18px;
			font-weight: 900;
			color: var(--green);
			letter-spacing: -0.5px;
			font-variant-numeric: tabular-nums;
		}
		.calc-cta {
			display: flex;
			align-items: center;
			justify-content: center;
			gap: 8px;
			background: var(--green);
			color: #000;
			font-size: 14px;
			font-weight: 800;
			padding: 12px 20px;
			border-radius: 10px;
			text-decoration: none;
			transition: background 0.2s, transform 0.15s;
			letter-spacing: -0.2px;
		}
		.calc-cta:hover { background: var(--green-dark); transform: translateY(-1px); }
		.calc-disclaimer {
			font-size: 11px;
			color: var(--muted);
			margin-top: 10px;
			text-align: center;
		}

		.hero h1 {
			font-size: clamp(38px, 7vw, 72px);
			font-weight: 900;
			line-height: 1.04;
			letter-spacing: -2.5px;
			color: #fff;
			margin-bottom: 24px;
			opacity: 0;
			animation: fadeSlideUp 0.8s ease 0.5s both;
		}
		.hero h1 .line-green { color: var(--green); display: block; }
		.hero h1 .line-muted { color: rgba(255,255,255,0.5); font-weight: 400; font-size: 0.72em; display: block; font-style: italic; letter-spacing: -1px; }
		.hero-sub {
			font-size: 18px;
			color: var(--muted2);
			line-height: 1.65;
			max-width: 560px;
			margin-bottom: 40px;
			opacity: 0;
			animation: fadeSlideUp 0.8s ease 0.7s both;
		}

		/* Countdown */
		.countdown-block {
			display: inline-flex;
			flex-direction: column;
			gap: 8px;
			margin-bottom: 36px;
			opacity: 0;
			animation: fadeSlideUp 0.8s ease 0.8s both;
		}
		.countdown-label {
			font-size: 11px;
			font-weight: 600;
			color: var(--amber);
			text-transform: uppercase;
			letter-spacing: 2px;
		}
		.countdown-units {
			display: flex;
			gap: 8px;
			align-items: center;
		}
		.countdown-unit {
			display: flex;
			flex-direction: column;
			align-items: center;
			background: rgba(255,255,255,0.06);
			border: 1px solid rgba(255,255,255,0.1);
			border-radius: 10px;
			padding: 10px 16px;
			min-width: 64px;
			transition: border-color 0.3s;
		}
		.countdown-unit.tick { border-color: rgba(0,179,126,0.4); }
		.countdown-num {
			font-size: 26px;
			font-weight: 900;
			color: #fff;
			line-height: 1;
			letter-spacing: -1px;
			font-variant-numeric: tabular-nums;
		}
		.countdown-sub {
			font-size: 10px;
			color: var(--muted);
			text-transform: uppercase;
			letter-spacing: 1px;
			margin-top: 4px;
		}
		.countdown-sep { font-size: 22px; color: var(--muted); font-weight: 300; margin-bottom: 14px; }

		.hero-cta {
			display: flex;
			flex-direction: column;
			align-items: flex-start;
			gap: 14px;
			opacity: 0;
			animation: fadeSlideUp 0.8s ease 1s both;
		}
		.btn-main {
			display: inline-flex;
			align-items: center;
			gap: 12px;
			background: var(--green);
			color: #000;
			font-size: 18px;
			font-weight: 800;
			padding: 18px 44px;
			border-radius: 12px;
			text-decoration: none;
			letter-spacing: -0.3px;
			transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
			box-shadow: 0 0 40px rgba(0,179,126,0.3);
			position: relative;
			overflow: hidden;
		}
		.btn-main::before {
			content: '';
			position: absolute;
			top: 0; left: -100%;
			width: 60%;
			height: 100%;
			background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
			transition: left 0.6s;
		}
		.btn-main:hover::before { left: 150%; }
		.btn-main:hover {
			background: var(--green-dark);
			transform: translateY(-2px);
			box-shadow: 0 0 60px rgba(0,179,126,0.45);
		}
		.btn-icon { font-size: 20px; transition: transform 0.2s; }
		.btn-main:hover .btn-icon { transform: translateX(4px); }

		.hero-price { font-size: 14px; color: var(--muted2); }
		.hero-price s { color: var(--muted); }
		.hero-price strong { color: #fff; font-size: 18px; }

		.hero-trust {
			display: flex;
			gap: 20px;
			flex-wrap: wrap;
			margin-top: 8px;
		}
		.trust-pill {
			display: flex;
			align-items: center;
			gap: 6px;
			font-size: 12px;
			color: var(--muted2);
		}
		.trust-pill-dot { color: var(--green); font-size: 10px; }

		/* ─── PROOF MARQUEE ─── */
		.proof-strip {
			background: var(--green);
			padding: 14px 24px;
			text-align: center;
			font-size: 14px;
			font-weight: 700;
			color: #000;
			letter-spacing: 0.3px;
			overflow: hidden;
		}
		.proof-strip-inner {
			display: inline-flex;
			gap: 48px;
			animation: marquee 26s linear infinite;
			white-space: nowrap;
		}
		@keyframes marquee {
			0% { transform: translateX(0); }
			100% { transform: translateX(-50%); }
		}

		/* ─── VSL SECTION ─── */
		.vsl {
			background: var(--black);
			padding: 80px 40px;
			text-align: center;
			position: relative;
			overflow: hidden;
		}
		.vsl::before {
			content: '';
			position: absolute;
			top: 50%; left: 50%;
			transform: translate(-50%, -50%);
			width: 800px; height: 500px;
			background: radial-gradient(ellipse, rgba(0,179,126,0.08) 0%, transparent 60%);
			pointer-events: none;
		}
		.vsl-inner { max-width: 900px; margin: 0 auto; position: relative; }
		.vsl-overline {
			font-size: 11px;
			font-weight: 700;
			color: var(--amber);
			text-transform: uppercase;
			letter-spacing: 2.5px;
			margin-bottom: 14px;
		}
		.vsl h2 {
			font-size: clamp(24px, 4vw, 36px);
			font-weight: 900;
			color: #fff;
			letter-spacing: -1.5px;
			line-height: 1.15;
			margin-bottom: 36px;
			max-width: 640px;
			margin-left: auto;
			margin-right: auto;
		}
		.vsl h2 em { color: var(--green); font-style: normal; }
		.vsl-frame {
			position: relative;
			aspect-ratio: 16 / 9;
			max-width: 760px;
			margin: 0 auto;
			border-radius: 18px;
			overflow: hidden;
			background:
				linear-gradient(135deg, rgba(0,179,126,0.1), rgba(8,12,18,0.95)),
				#0d1520;
			border: 1px solid var(--border);
			box-shadow: 0 24px 80px rgba(0,0,0,0.6);
			cursor: pointer;
			display: flex;
			align-items: center;
			justify-content: center;
			transition: transform 0.3s, box-shadow 0.3s;
		}
		.vsl-frame:hover {
			transform: translateY(-2px);
			box-shadow: 0 32px 100px rgba(0,179,126,0.2), 0 0 0 1px rgba(0,179,126,0.3);
		}
		.vsl-frame::before {
			content: '';
			position: absolute;
			inset: 0;
			background-image:
				linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
				linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
			background-size: 32px 32px;
			pointer-events: none;
		}
		.vsl-play {
			width: 92px; height: 92px;
			background: var(--green);
			border-radius: 50%;
			display: flex;
			align-items: center;
			justify-content: center;
			position: relative;
			z-index: 1;
			box-shadow: 0 0 0 0 rgba(0,179,126,0.4);
			animation: pulse-play 2.5s ease infinite;
			transition: transform 0.2s;
		}
		.vsl-frame:hover .vsl-play { transform: scale(1.06); }
		@keyframes pulse-play {
			0% { box-shadow: 0 0 0 0 rgba(0,179,126,0.5); }
			100% { box-shadow: 0 0 0 28px rgba(0,179,126,0); }
		}
		.vsl-play-icon {
			width: 0; height: 0;
			border-left: 26px solid #000;
			border-top: 16px solid transparent;
			border-bottom: 16px solid transparent;
			margin-left: 6px;
		}
		.vsl-caption {
			position: absolute;
			bottom: 24px; left: 50%;
			transform: translateX(-50%);
			background: rgba(0,0,0,0.75);
			color: var(--text);
			font-size: 13px;
			font-weight: 600;
			padding: 6px 14px;
			border-radius: 20px;
			z-index: 1;
		}
		.vsl-meta {
			display: flex;
			justify-content: center;
			gap: 24px;
			flex-wrap: wrap;
			margin-top: 24px;
			color: var(--muted);
			font-size: 13px;
		}
		.vsl-meta-item { display: flex; align-items: center; gap: 6px; }

		/* VSL MODAL */
		.modal {
			position: fixed;
			inset: 0;
			background: rgba(0,0,0,0.85);
			backdrop-filter: blur(8px);
			z-index: 500;
			display: none;
			align-items: center;
			justify-content: center;
			padding: 24px;
			animation: modalFade 0.25s ease;
		}
		.modal.open { display: flex; }
		@keyframes modalFade {
			from { opacity: 0; }
			to { opacity: 1; }
		}
		.modal-box {
			background: var(--dark);
			border: 1px solid var(--border);
			border-radius: 18px;
			padding: 48px 36px;
			max-width: 480px;
			text-align: center;
			position: relative;
		}
		.modal-close {
			position: absolute;
			top: 16px; right: 16px;
			background: rgba(255,255,255,0.06);
			border: 1px solid var(--border);
			color: var(--text);
			width: 32px; height: 32px;
			border-radius: 50%;
			cursor: pointer;
			font-size: 18px;
			display: flex;
			align-items: center;
			justify-content: center;
			transition: background 0.15s;
		}
		.modal-close:hover { background: rgba(255,255,255,0.1); }
		.modal-box h3 { font-size: 22px; font-weight: 800; color: #fff; margin-bottom: 12px; letter-spacing: -0.5px; }
		.modal-box p { color: var(--muted2); font-size: 15px; line-height: 1.6; margin-bottom: 24px; }
		.modal-cta {
			display: inline-block;
			background: var(--green);
			color: #000;
			font-weight: 800;
			padding: 12px 28px;
			border-radius: 10px;
			text-decoration: none;
			font-size: 15px;
			transition: background 0.2s;
		}
		.modal-cta:hover { background: var(--green-dark); }

		/* ─── PAIN ─── */
		.pain {
			background: var(--off-white);
			padding: 100px 40px;
			color: #0d1520;
		}
		.pain-inner {
			max-width: 1100px;
			margin: 0 auto;
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 80px;
			align-items: start;
		}
		@media (max-width: 800px) {
			.pain-inner { grid-template-columns: 1fr; gap: 48px; }
		}
		.pain-overline {
			font-size: 11px;
			font-weight: 700;
			color: var(--red);
			text-transform: uppercase;
			letter-spacing: 2.5px;
			margin-bottom: 20px;
		}
		.pain h2 {
			font-size: clamp(32px, 5vw, 52px);
			font-weight: 900;
			line-height: 1.05;
			letter-spacing: -2px;
			color: var(--dark);
			margin-bottom: 24px;
		}
		.pain h2 em { font-style: normal; color: var(--red); }
		.pain-text {
			font-size: 17px;
			color: #475569;
			line-height: 1.7;
			max-width: 420px;
		}
		.pain-right { display: flex; flex-direction: column; gap: 14px; }
		.pain-item {
			display: flex;
			gap: 16px;
