			border-color: rgba(0,179,126,0.25);
			color: var(--green);
		}
		.pay-icon { font-size: 16px; }

		/* ─── SOCIAL PROOF TOAST ─── */
		.toast-wrap {
			position: fixed;
			bottom: 24px; left: 24px;
			z-index: 300;
			pointer-events: none;
		}
		.toast {
			background: rgba(13,21,32,0.96);
			backdrop-filter: blur(12px);
			border: 1px solid var(--border);
			border-left: 3px solid var(--green);
			border-radius: 12px;
			padding: 12px 18px 12px 14px;
			max-width: 320px;
			display: flex;
			gap: 12px;
			align-items: center;
			box-shadow: 0 16px 48px rgba(0,0,0,0.5);
			pointer-events: auto;
			opacity: 0;
			transform: translateY(20px);
			transition: opacity 0.45s ease, transform 0.45s ease;
		}
		.toast.show { opacity: 1; transform: translateY(0); }
		.toast-icon {
			width: 32px; height: 32px;
			background: rgba(0,179,126,0.15);
			border-radius: 50%;
			display: flex;
			align-items: center;
			justify-content: center;
			color: var(--green);
			font-size: 14px;
			flex-shrink: 0;
		}
		.toast-body { flex: 1; min-width: 0; }
		.toast-title { font-size: 13px; font-weight: 700; color: #fff; margin-bottom: 2px; }
		.toast-text { font-size: 12px; color: var(--muted2); line-height: 1.4; }
		@media (max-width: 640px) {
			.toast-wrap { display: none; }
		}

		/* ─── FOOTER ─── */
		.footer {
			background: #040810;
			padding: 28px 40px;
			border-top: 1px solid var(--border);
			text-align: center;
			color: var(--muted);
			font-size: 13px;
		}
		.footer a { color: #475569; text-decoration: none; margin: 0 10px; }
		.footer a:hover { color: var(--muted2); }

		/* ─── REVEAL ─── */
		.r {
			opacity: 0;
			transform: translateY(36px);
			transition: opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1), transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
		}
		.r.from-left { transform: translateX(-44px); }
		.r.from-right { transform: translateX(44px); }
		.r.from-scale { transform: scale(0.92); }
		.r.visible { opacity: 1; transform: translate(0) scale(1); }
		.r.d1 { transition-delay: 0.1s; }
		.r.d2 { transition-delay: 0.2s; }
		.r.d3 { transition-delay: 0.3s; }
		.r.d4 { transition-delay: 0.4s; }
		.r.d5 { transition-delay: 0.5s; }

		/* ─── RESPONSIVE ─── */
		@media (max-width: 640px) {
			.hero { padding: 100px 24px 60px; }
			.pain, .product, .modules, .bonus, .testimonials, .guarantee, .faq, .cta-final, .vsl, .trust-section { padding: 60px 24px; }
